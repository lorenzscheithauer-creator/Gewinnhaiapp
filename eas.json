{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "withoutCredentials": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://www.gewinnhai.de",
        "EXPO_PUBLIC_API_TIMEOUT_MS": "10000",
        "EXPO_PUBLIC_ENDPOINTS_GIVEAWAYS": "/api/giveaways,/wp-json/wp/v2/posts",
        "EXPO_PUBLIC_ENDPOINTS_GIVEAWAY_DETAIL": "/api/giveaways/{idOrSlug},/wp-json/wp/v2/posts/{idOrSlug}",
        "EXPO_PUBLIC_ENDPOINTS_CATEGORIES": "/api/categories,/wp-json/wp/v2/categories",
        "EXPO_PUBLIC_ENDPOINTS_TOP10": "/api/top10,/wp-json/wp/v2/posts",
        "EXPO_PUBLIC_APP_ENV": "preview"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://www.gewinnhai.de",
        "EXPO_PUBLIC_API_TIMEOUT_MS": "10000",
        "EXPO_PUBLIC_ENDPOINTS_GIVEAWAYS": "/api/giveaways,/wp-json/wp/v2/posts",
        "EXPO_PUBLIC_ENDPOINTS_GIVEAWAY_DETAIL": "/api/giveaways/{idOrSlug},/wp-json/wp/v2/posts/{idOrSlug}",
        "EXPO_PUBLIC_ENDPOINTS_CATEGORIES": "/api/categories,/wp-json/wp/v2/categories",
        "EXPO_PUBLIC_ENDPOINTS_TOP10": "/api/top10,/wp-json/wp/v2/posts",
        "EXPO_PUBLIC_APP_ENV": "production"
      },
      "android": {
        "buildType": "app-bundle",
        "withoutCredentials": false
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {}
  }
}
