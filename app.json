{
  "expo": {
    "name": "Gewinnhai",
    "slug": "gewinnhai-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gewinnhai",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f9fb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_ERROR_RECOVERY"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gewinnhai.mobile",
      "buildNumber": "1.0.1",
      "requireFullScreen": true,
      "infoPlist": {
        "CFBundleDisplayName": "Gewinnhai",
        "LSApplicationQueriesSchemes": [
          "http",
          "https",
          "mailto",
          "tel"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      },
      "associatedDomains": [
        "applinks:gewinnhai.de",
        "applinks:www.gewinnhai.de"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f7f9fb"
      },
      "package": "com.gewinnhai.mobile",
      "versionCode": 2,
      "permissions": [
        "INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "https",
              "host": "gewinnhai.de",
              "pathPrefix": "/gewinnspiel"
            },
            {
              "scheme": "https",
              "host": "www.gewinnhai.de",
              "pathPrefix": "/gewinnspiel"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "softwareKeyboardLayoutMode": "pan",
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "extra": {
      "apiBaseUrl": "https://www.gewinnhai.de",
      "apiTimeoutMs": 10000,
      "endpoints": {
        "giveaways": [
          "/api/giveaways",
          "/wp-json/wp/v2/posts"
        ],
        "giveawayDetail": [
          "/api/giveaways/{idOrSlug}",
          "/wp-json/wp/v2/posts/{idOrSlug}"
        ],
        "categories": [
          "/api/categories",
          "/wp-json/wp/v2/categories"
        ],
        "top10": [
          "/api/top10",
          "/wp-json/wp/v2/posts"
        ]
      },
      "appEnv": "production"
    },
    "androidStatusBar": {
      "backgroundColor": "#ffffff",
      "barStyle": "dark-content"
    }
  }
}
