{
  "expo": {
    "name": "Gewinnhai",
    "slug": "gewinnhai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gewinnhai",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gewinnhai.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.gewinnhai.mobile"
    },
    "extra": {
      "apiBaseUrl": "https://www.gewinnhai.de",
      "apiTimeoutMs": 10000,
      "endpoints": {
        "giveaways": [
          "/api/giveaways",
          "/wp-json/wp/v2/posts"
        ],
        "giveawayDetail": [
          "/api/giveaways/{idOrSlug}",
          "/wp-json/wp/v2/posts/{idOrSlug}"
        ],
        "categories": [
          "/api/categories",
          "/wp-json/wp/v2/categories"
        ],
        "top10": [
          "/api/top10",
          "/wp-json/wp/v2/posts"
        ]
      }
    }
  }
}
